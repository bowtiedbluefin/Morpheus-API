# Database Configuration
POSTGRES_USER=morpheus_user
POSTGRES_PASSWORD=morpheus_password
POSTGRES_DB=morpheus_db
DATABASE_URL=postgresql+asyncpg://morpheus_user:morpheus_password@db:5432/morpheus_db

# Redis Configuration
REDIS_PASSWORD=supersecretredis
REDIS_URL=redis://:supersecretredis@redis:6379/0

# Application Settings
API_ENV=development  # development, staging, production
APP_DEBUG=true
LOG_LEVEL=INFO
PORT=8000

# Security
JWT_SECRET_KEY=your_super_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Proxy Router Settings
PROXY_ROUTER_URL=http://localhost:8545

# KMS Configuration
KMS_PROVIDER=aws
KMS_MASTER_KEY_ID=your_master_key_id

# AWS/KMS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_SESSION_TOKEN=your_session_token_if_needed
AWS_KMS_KEY_ID=your_kms_key_id 